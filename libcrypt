#!/usr/bin/env zsh

zmodload zsh/system

genrnd() {
  unset working_num_raw
  unset conv_to_decimal
  unset working_num
  keyln=127
  genrnd_count=0
  exec {fd}< /dev/urandom
  while sysread -i $fd -s 1 working_num_raw; do
    grnd_out=$(printf "%02x" "'$working_num_raw")
    genrnd_chk=$((16#$grnd_out))
    (((genrnd_chk<32)) || ((genrnd_chk>126))) && {
      until (((genrnd_chk>=32)) && ((genrnd_chk<=126))); do
        unset working_num_raw
        sysread -i $fd -s 1 working_num_raw
        grnd_out=$(printf "%02x" "'$working_num_raw")
        genrnd_chk=$((16#$grnd_out))
      done
    }
    printf "%s" "$grnd_out"
    ((genrnd_count==keyln)) && {
      break
    }
    ((genrnd_count++))
  done
  exec {fd}<&-
  return 0
}

gen_key() {
  rnd_dat=$(genrnd)
  rnd_ln=${#rnd_dat}
  for ((i=0; i<$rnd_ln; i++)); do
    print -n "\x"${rnd_dat:$i:2}""
    ((i++))
  done
}

krevstr() {
  local str="$1"
  local reversed
  for ((i=$#str; i>0; i--)); do
    reversed+="${str[$i,$i]}"
  done
  print -r "$reversed"
}

do_bitwise_xor() {
  a=$(printf "%02x" "'$1")
  b=$(printf "%02x" "'$2")
  conv=$(([##16]0x$a^0x$b))
  ((${#conv}<2)) && {
    conv="0"$conv""
  }
  print -n "\x"$conv""
}

gen_xl_key() {
  output_buffer=''
  until [[ ${#output_buffer} -ge 256 ]]; do
    output_buffer=""$output_buffer""$(gen_key)""
  done
  output_buffer=${output_buffer::256}
  noglob printf "%s" "$output_buffer"
}

gen_small_key() {
  output_buffer=$(gen_key)
  output_buffer=${output_buffer::64}
  noglob printf "%s" "$output_buffer"
}

do_crypt() {
  # fetch key name, error if key not exist
  target_key="$1"
  ! [ -f "$target_key" ] && {
    print "Error: key not exist"
    return 1
  }
  # read in target key from file (we can just use $(< $file) since we dont care about newline preservation on keyfile)
  target_key=$(< "$target_key")
  # error if key empty
  [ -z "$target_key" ] && {
    print "Error: provided key is empty"
    return 1
  }
  # error if key too small
  ((${#target_key}<64)) && {
    print "Error: provided key is too small (min size 64 byte)"
    return 1
  }
  target_key_ln=${#target_key}
  # convert key to array
  unset cryptkey
  declare -a cryptkey
  while true; do
    key_indice=${target_key::1}
    target_key=${target_key:1}
    [ -z "$key_indice" ] && {
      break
    }
    cryptkey+=("$key_indice")
  done
  # fetch target data, error if empty
  target_data="$2"
  [ -z "$target_data" ] && {
    print "Error: target data is empty!"
    return 1
  }
  # if data is file; read like one
  [ -f "$target_data" ] && {
    ! ((decrypt==1)) && {
      [ -f ""$target_data".crypt" ] && {
        rm -rf ""$target_data".crypt"
      }
      print -n '' > ""$target_data".crypt"
    }
    # if we're decrypting, check for .crypt extension on target
    ((decrypt==1)) && {
      target_orig=$(krevstr "$target_data")
      target_safety_check=${target_orig::6}
      target_safety_check=$(krevstr "$target_safety_check")
      [ "$target_safety_check" != '.crypt' ] && {
        [ "$override_safety" != 1 ] && {
          print "Error: target does not appear to be a .crypt file"
          return 1
        } || {
          print "Warn: target does not appear to be a .crypt file"
        }
      }
      target_orig=${target_orig:6}
      target_orig=$(krevstr "$target_orig")
      [ -f "$target_orig" ] && {
        rm -rf "$target_orig"
      }
      print -n '' > "$target_orig"
    }
    # open file descriptor, read 1 byte at a time
    exec {filedat}< "$target_data"
    key_counter=1
    while sysread -i $filedat -s 1 char; do
      keychar=$cryptkey[$key_counter]
      ((decrypt==1)) && {
        do_bitwise_xor "$char" "$keychar" >> "$target_orig"
      } || {
        do_bitwise_xor "$char" "$keychar" >> ""$target_data".crypt"
      }
      ((key_counter++))
      ((key_counter>target_key_ln)) && {
        key_counter=1
      }
    done
    exec {filedat}<&-
  # else if data isnt a file
  } || {
    keycounter=1
    while true; do
      char=${target_data::1}
      target_data=${target_data:1}
      [ -z "$char" ] && {
        break
      }
      keychar=$cryptkey[$key_counter]
      do_bitwise_xor "$char" "$keychar"
      ((keycounter++))
      ((keycounter>target_key_ln)) && {
        keycounter=1
      }
    done
  }
}

